<script>
  // Nav scroll style
  const nav = document.getElementById('mainNav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  });

  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));

  // Hero content fade-in delay
  document.querySelector('.hero-content').style.animationDelay = '0.5s';

  // Form → WhatsApp
  function handleSubmit() {
    const fnameEl    = document.getElementById('fname');
    const phoneEl    = document.getElementById('phone');
    const interestEl = document.getElementById('interest');
    const errorEl    = document.getElementById('form-error');

    // Clear previous errors
    [fnameEl, phoneEl, interestEl].forEach(el => el.classList.remove('input-error'));
    errorEl.style.display = 'none';

    const fname    = fnameEl.value.trim();
    const phone    = phoneEl.value.trim();
    const interest = interestEl.value;

    const missing = [];
    if (!fname)    { fnameEl.classList.add('input-error');    missing.push('First Name'); }
    if (!phone)    { phoneEl.classList.add('input-error');    missing.push('Phone Number'); }
    if (!interest) { interestEl.classList.add('input-error'); missing.push('Interested In'); }

    if (missing.length) {
      errorEl.textContent = `Please fill in: ${missing.join(', ')}`;
      errorEl.style.display = 'block';
      return;
    }

    const lname = document.getElementById('lname').value.trim();
    const msg   = document.getElementById('msg').value.trim();
    const name  = [fname, lname].filter(Boolean).join(' ');

    const text = `Hello Truhomes Realty! 👋\n\n` +
      `*Name:* ${name}\n` +
      `*Phone:* ${phone}\n` +
      `*Interested In:* ${interest}\n` +
      `*Message:* ${msg || 'No message'}\n\n` +
      `_(Sent via truhomes website)_`;

    const waUrl = `https://wa.me/919223216888?text=${encodeURIComponent(text)}`;
    window.open(waUrl, '_blank');
  }
</script>
